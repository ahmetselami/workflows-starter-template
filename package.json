{
	"name": "lenitsa-translate",
	"private": true,
	"version": "2.0.0",
	"description": "Cloudflare Workers AI Translation Engine with KV caching and multi-language support",
	"cloudflare": {
		"label": "Lenitsa Translate",
		"products": [
			"Workers",
			"Workers AI",
			"KV Storage"
		],
		"categories": [
			"translation"
		],
		"publish": true
	},
	"type": "module",
	"scripts": {
		"dev": "wrangler dev",
		"build": "tsc -b && wrangler build",
		"check": "tsc && wrangler deploy --dry-run",
		"lint": "eslint .",
		"preview": "npm run build && wrangler preview",
		"deploy": "npm run build && wrangler deploy",
		"deploy:production": "npm run build && wrangler deploy --env production",
		"deploy:staging": "npm run build && wrangler deploy --env staging",
		"deploy:development": "wrangler dev --env development",
		"cf-typegen": "wrangler types",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"dependencies": {},
	"devDependencies": {
		"@cloudflare/workers-types": "^4.20250101.0",
		"@types/node": "^20.0.0",
		"@eslint/js": "^9.33.0",
		"eslint": "^9.33.0",
		"typescript": "~5.8.3",
		"typescript-eslint": "^8.39.1",
		"wrangler": "^4.51.0",
		"vitest": "3.2.x"
	},
	"engines": {
		"node": ">=20.0.0"
	}
}
